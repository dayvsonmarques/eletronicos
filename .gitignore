# Ignora todos os arquivos do WordPress exceto o tema customizado

/*

!.gitignore
!wp-content/
wp-content/*
!wp-content/themes/
wp-content/themes/*
!wp-content/themes/storefront-child/
!wp-content/themes/storefront-child/**

# CSS compilado (gerado via npm run build / watch)
wp-content/themes/storefront-child/assets/css/

# Arquivos sensíveis
wp-config.php
wp-content/debug.log

# Arquivos temporários e de sistema
*.log
*.tmp
.DS_Store
Thumbs.db
