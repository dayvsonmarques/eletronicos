# .gitignore para WordPress
# Ignora todos os arquivos do WordPress exceto temas personalizados e instruções de plugins

# Ignorar tudo
/*

# Não ignorar este .gitignore
!.gitignore

# Não ignorar a pasta de temas personalizados
!wp-content/
wp-content/*
!wp-content/themes/
wp-content/themes/*
!wp-content/themes/storefront-child/
!wp-content/themes/storefront-child/**

# CSS compilado (gerado via sass --watch / npm run build)
wp-content/themes/storefront-child/assets/css/

# Não ignorar instruções de plugins
!plugins-instrucoes.txt

# Não ignorar documentação e scripts do projeto
!PROJECT-GUIDELINES.md
!importar_imagens_produtos.php
!cadastrar_produtos.sh
!atualizar_precos.sh
!atualizar_categorias_produtos.sh

# Permitir uploads de imagens de exemplo (opcional)
#!wp-content/uploads/

# Ignorar arquivos sensíveis
wp-config.php
wp-content/debug.log

# Ignorar arquivos temporários
*.log
*.tmp

# Ignorar arquivos do sistema
.DS_Store
Thumbs.db
